print("✅ GC连点器 iPad/Delta适配版 加载成功！")
print("📌 拖动「1」按钮到需要点击的位置")
print("▶️  点击左侧Play开始连点，CPS面板可调节速度")
pcall(function()
    game.StarterGui:SetCore("SendNotification", {Title = "加载成功", Text = "拖动「1」定位 | 左侧Play开始", Duration = 3})
end)
