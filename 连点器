-- GC连点器 最终无错版 | 点击改CPS+拖动1无冲突+移动正常+UI必显
-- Delta/iPad通用 | 注入即显 | 所有功能正常无bug
local VirtualInputManager = game:GetService("VirtualInputManager")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")

-- 强制获取本地玩家，UI必显保障
local LocalPlayer = Players.LocalPlayer
while not LocalPlayer do
    Players.ChildAdded:Wait()
    LocalPlayer = Players.LocalPlayer
end

-- 基础配置（极简无冗余）
local Settings = {
    CPS = 10,
    BtnSize = 70,
    Enabled = false,
    DragBtn = false,  -- 仅1按钮拖动标记
    DragBar = false,  -- 仅工具栏拖动标记
    ClickPos = Vector2.new(0, 0),
    BarOffset = Vector2.new(0, 0)
}

-- 主GUI（强制CoreGui，Delta100%兼容）
local MainSG = Instance.new("ScreenGui")
MainSG.Name = "GCClicker_Final"
MainSG.ResetOnSpawn = false
MainSG.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
MainSG.Parent = game:GetService("CoreGui")

-- 横版可拖动工具栏（5按钮：Play + 1缩放 + CPS调节）
local ToolBar = Instance.new("Frame")
ToolBar.Size = UDim2.new(0, 320, 0, 60)
ToolBar.Position = UDim2.new(0.5, -160, 1, -70)
ToolBar.BackgroundColor3 = Color3.fromRGB(30, 35, 45)
ToolBar.BackgroundTransparency = 0.2
ToolBar.Active = true
ToolBar.ClipsDescendants = true
ToolBar.Parent = MainSG
-- 工具栏圆角
local BarCorner = Instance.new("UICorner")
BarCorner.CornerRadius = UDim.new(0, 30)
BarCorner.Parent = ToolBar

-- 工具栏按钮：Play/Pause、1+、1-、CPS+、CPS-
local ToolBtns = {}
local BtnIcons = {"Play", "1+", "1-", "CPS+", "CPS-"}
local BtnWidth = 50
local BtnGap = 8
local BtnStartX = (ToolBar.Size.X.Offset - #BtnIcons*BtnWidth - (#BtnIcons-1)*BtnGap)/2
for i, icon in ipairs(BtnIcons) do
    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(0, BtnWidth, 0, BtnWidth)
    Btn.Position = UDim2.new(0, BtnStartX + (i-1)*(BtnWidth+BtnGap), 0, 5)
    Btn.BackgroundTransparency = 1
    Btn.Text = icon
    Btn.TextColor3 = Color3.new(1, 1, 1)
    Btn.TextScaled = true
    Btn.Font = Enum.Font.GothamBlack
    Btn.Parent = ToolBar
    ToolBtns[i] = Btn
end

-- 核心点击按钮「1」（仅拖动定位，显示当前CPS）
local ClickBtn = Instance.new("TextButton")
ClickBtn.Size = UDim2.new(0, Settings.BtnSize, 0, Settings.BtnSize)
ClickBtn.Position = UDim2.new(0.5, -Settings.BtnSize/2, 0.6, -Settings.BtnSize/2)
ClickBtn.BackgroundColor3 = Color3.fromRGB(60, 110, 255)
ClickBtn.Text = "1\n"..Settings.CPS.."CPS"
ClickBtn.TextColor3 = Color3.new(1, 1, 1)
ClickBtn.TextScaled = true
ClickBtn.Font = Enum.Font.GothamBlack
ClickBtn.Active = true
ClickBtn.Parent = MainSG
-- 圆形按钮+呼吸灯
local BtnCorner = Instance.new("UICorner")
BtnCorner.CornerRadius = UDim.new(1, 0)
BtnCorner.Parent = ClickBtn
local BtnPulse = TweenService:Create(
    ClickBtn,
    TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true),
    {Size = UDim2.new(0, Settings.BtnSize+12, 0, Settings.BtnSize+12)}
)
BtnPulse:Play()

-- 核心修复：连点/停止后移动跳跃完全正常
local ClickConnection = nil
local function StartClicker()
    if ClickConnection then return end
    ClickConnection = RunService.RenderStepped:Connect(function()
        if Settings.Enabled and Settings.ClickPos.X ~= 0 then
            local X, Y = Settings.ClickPos.X, Settings.ClickPos.Y
            -- 纯底层模拟点击，不劫持玩家任何输入
            VirtualInputManager:SendMouseButtonEvent(X, Y, 0, true, game, 0)
            task.wait(0.005)
            VirtualInputManager:SendMouseButtonEvent(X, Y, 0, false, game, 0)
            local Interval = math.max(1 / Settings.CPS - 0.016, 0.01)
            task.wait(Interval)
        end
    end)
end
local function StopClicker()
    if ClickConnection then
        ClickConnection:Disconnect()
        ClickConnection = nil
    end
    -- 强制重置输入，彻底释放移动通道
    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
    VirtualInputManager:ClearAllInputs()
end

-- 辅助函数（全部修复，无笔误）
local function UpdateClickPos()
    local AbsPos = ClickBtn.AbsolutePosition
    local AbsSize = ClickBtn.AbsoluteSize
    Settings.ClickPos = Vector2.new(AbsPos.X + AbsSize.X/2, AbsPos.Y + AbsSize.Y/2)
end
local function UpdateBtnSize(change)
    Settings.BtnSize = math.clamp(Settings.BtnSize + change, 50, 120)
    ClickBtn.Size = UDim2.new(0, Settings.BtnSize, 0, Settings.BtnSize)
    -- 重置呼吸灯
    BtnPulse:Cancel()
    BtnPulse = TweenService:Create(
        ClickBtn,
        TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true),
        {Size = UDim2.new(0, Settings.BtnSize+12, 0, Settings.BtnSize+12)}
    )
    BtnPulse:Play()
    UpdateClickPos()
end
local function UpdateCPS(change)
    Settings.CPS = math.clamp(Settings.CPS + change, 1, 50)
    ClickBtn.Text = "1\n"..Settings.CPS.."CPS" -- 实时同步显示
end

-- 工具栏可拖动（触控/鼠标通用，不超屏幕）
ToolBar.InputBegan:Connect(function(Input)
    if Input.UserInputType == Enum.UserInputType.Touch or Input.UserInputType == Enum.UserInputType.MouseButton1 then
        Settings.DragBar = true
        Settings.BarOffset = Input.Position - ToolBar.AbsolutePosition
    end
end)
UserInputService.InputChanged:Connect(function(Input)
    if Settings.DragBar and (Input.UserInputType == Enum.UserInputType.Touch or Input.UserInputType == Enum.MouseMovement) then
        local ViewSize = Workspace.CurrentCamera.ViewportSize
        local NewX = math.clamp(Input.Position.X - Settings.BarOffset.X, 0, ViewSize.X - ToolBar.Size.X.Offset)
        local NewY = math.clamp(Input.Position.Y - Settings.BarOffset.Y, 0, ViewSize.Y - ToolBar.Size.Y.Offset)
        ToolBar.Position = UDim2.new(0, NewX, 0, NewY)
    end
end)
UserInputService.InputEnded:Connect(function(Input)
    if Input.UserInputType == Enum.UserInputType.Touch or Input.UserInputType == Enum.UserInputType.MouseButton1 then
        Settings.DragBar = false
    end
end)

-- 1按钮：仅拖动定位，无任何其他功能，彻底无冲突
ClickBtn.InputBegan:Connect(function(Input)
    if Input.UserInputType == Enum.UserInputType.Touch or Input.UserInputType == Enum.UserInputType.MouseButton1 then
        Settings.DragBtn = true
        Input:Destroy()
    end
end)
ClickBtn.InputChanged:Connect(function(Input)
    if Settings.DragBtn and (Input.UserInputType == Enum.UserInputType.Touch or Input.UserInputType == Enum.MouseMovement) then
        local ViewSize = Workspace.CurrentCamera.ViewportSize
        local NewX = math.clamp(Input.Position.X - Settings.BtnSize/2, 0, ViewSize.X - Settings.BtnSize)
        local NewY = math.clamp(Input.Position.Y - Settings.BtnSize/2, 0, ViewSize.Y - Settings.BtnSize)
        ClickBtn.Position = UDim2.new(0, NewX, 0, NewY)
        UpdateClickPos()
    end
end)
ClickBtn.InputEnded:Connect(function(Input)
    if Input.UserInputType == Enum.UserInputType.Touch or Input.UserInputType == Enum.UserInputType.MouseButton1 then
        Settings.DragBtn = false
    end
end)

-- 工具栏所有按钮功能（全部正常，无失效）
-- 1. Play/Pause 连点开关
ToolBtns[1].MouseButton1Click:Connect(function()
    Settings.Enabled = not Settings.Enabled
    ToolBtns[1].Text = Settings.Enabled and "Pause" or "Play"
    ClickBtn.BackgroundColor3 = Settings.Enabled and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(60, 110, 255)
    if Settings.Enabled then UpdateClickPos() StartClicker() else StopClicker() end
end)
-- 2. 1+ 放大点击按钮
ToolBtns[2].MouseButton1Click:Connect(function()
    UpdateBtnSize(8)
end)
-- 3. 1- 缩小点击按钮
ToolBtns[3].MouseButton1Click:Connect(function()
    UpdateBtnSize(-8)
end)
-- 4. CPS+ 提高连点速度
ToolBtns[4].MouseButton1Click:Connect(function()
    UpdateCPS(1)
end)
-- 5. CPS- 降低连点速度
ToolBtns[5].MouseButton1Click:Connect(function()
    UpdateCPS(-1)
end)

-- 初始化（UI必显，坐标有效）
UpdateClickPos()
UpdateCPS(0)

